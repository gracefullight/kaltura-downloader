{
  "name": "kaltura-downloader",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,css}": [
      "biome check --write --unsafe --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@napi-rs/canvas": "^0.1.97",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0"
  }
}
